# ================================================================
#  Suhaib Photo — Environment Variables Example
#  Copy this file to .env and fill in your values
# ================================================================

PORT=3000
NODE_ENV=development

# Admin password — used in the login modal (S button)
ADMIN_PASSWORD=your_strong_password_here

# JWT secret — long random string, MUST change in production
JWT_SECRET=change_this_to_a_very_long_random_string_in_production

# ----------------------------------------------------------------
#  MongoDB Atlas
#  Create a free cluster at https://cloud.mongodb.com
# ----------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ----------------------------------------------------------------
#  Cloudinary — https://cloudinary.com (free tier available)
#  IMPORTANT: variable name is CLOUD_NAME (not CLOUDINARY_CLOUD_NAME)
# ----------------------------------------------------------------
CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Watermark text stamped on uploaded images (default: "Suhaib Photo")
WATERMARK_TEXT=Suhaib Photo

# Your production domain for CORS — e.g. https://suhaibphoto.com
ALLOWED_ORIGIN=
